# Copy this file to `.env` and fill in your own keys. NEVER commit `.env`.
# The service reads everything from the environment — no secrets in code.

# Which price provider to use: stub | alphavantage | finnhub
# "stub" needs no key and returns SYNTHETIC data so you can run offline.
PRICE_PROVIDER=stub

# Default asset. Vinhomes trades on HOSE as VHM; many vendors want ".VN".
DEFAULT_TICKER=VHM.VN

# Annualized risk-free rate used in the Sharpe ratio (e.g. 0.04 = 4%).
RISK_FREE_RATE=0.04

# --- Market data providers (pick one, set PRICE_PROVIDER to match) ---
# Alpha Vantage free key: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=
# Finnhub free key: https://finnhub.io/register
FINNHUB_API_KEY=

# --- Satellite / alt-data (Sentinel Hub free tier) ---
# https://www.sentinel-hub.com/  ->  create an OAuth client
SENTINELHUB_CLIENT_ID=
SENTINELHUB_CLIENT_SECRET=
